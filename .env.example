# ==========================================
# 大模型配置（云端）
# ==========================================
OPENAI_API_KEY=sk-你的API密钥
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-ai/DeepSeek-V3

# ==========================================
# OpenAlex 配置
# ==========================================
# 注册地址：https://openalex.org/register
# 用于下载 content.openalex.org 的 PDF
OPENALEX_API_KEY=你的OpenAlex_API_Key

# ==========================================
# OpenAlex 注册邮箱（提升搜索频率限制）
# ==========================================
REGISTERED_EMAIL=your_email@example.com

# ==========================================
# Ollama 本地翻译模型
# ==========================================
# 拉取命令：ollama pull qwen2.5:7b
# 也可换成 command-r / llama3.1:8b 等
OLLAMA_MODEL=qwen2.5:7b